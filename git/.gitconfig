[init]
	defaultBranch = main

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[merge]
	conflictStyle = zdiff3

[pull]
	ff = only

[push]
	autoSetupRemote = true

[alias]
	br = branch
	co = checkout
	st = status --short --branch
	lg = log --graph --decorate --oneline --all
